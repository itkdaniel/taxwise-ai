# ── Development environment ───────────────────────────────────────────────────
# Copy to .env.development and fill in real values; never commit secrets.

APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1

# PostgreSQL (shared with Node.js API)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/taxwise
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis (optional — caching gracefully disabled if unavailable)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=google/gemini-flash-1.5

# LLM microservice
LLM_SERVICE_URL=http://localhost:9000

# CORS — allow all origins in development
CORS_ORIGINS=*
